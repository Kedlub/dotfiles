### Added by Zinit's installer
if [[ ! -f $HOME/.local/share/zinit/zinit.git/zinit.zsh ]]; then
    print -P "%F{33} %F{220}Installing %F{33}ZDHARMA-CONTINUUM%F{220} Initiative Plugin Manager (%F{33}zdharma-continuum/zinit%F{220})…%f"
    command mkdir -p "$HOME/.local/share/zinit" && command chmod g-rwX "$HOME/.local/share/zinit"
    command git clone https://github.com/zdharma-continuum/zinit "$HOME/.local/share/zinit/zinit.git" && \
        print -P "%F{33} %F{34}Installation successful.%f%b" || \
        print -P "%F{160} The clone has failed.%f%b"
fi

source "$HOME/.local/share/zinit/zinit.git/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit

# Load a few important annexes, without Turbo
# (this is currently required for annexes)
zinit light-mode for \
    zdharma-continuum/zinit-annex-as-monitor \
    zdharma-continuum/zinit-annex-bin-gem-node \
    zdharma-continuum/zinit-annex-patch-dl \
    zdharma-continuum/zinit-annex-rust

### End of Zinit's installer chunk

# Environment variables
export PATH="$HOME/bin:$HOME/.local/bin:$PATH"
export MANPAGER="bat -plman"

# Base look inherited by all fzf tools (zoxide overrides it, see _ZO_FZF_OPTS).
export FZF_DEFAULT_OPTS="
  --height=80%
  --layout=reverse
  --border
  --info=inline
  --cycle
"

# Completions
zinit light zsh-users/zsh-completions
autoload -Uz compinit; compinit

zinit ice lucid atinit"ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=20"
zinit light zsh-users/zsh-autosuggestions

# Abbreviations expand short commands into full commands before execution
zinit light olets/zsh-abbr

# Auto-pair quotes, brackets, and parentheses
zinit light hlissner/zsh-autopair

# fzf-tab
zinit light Aloxaf/fzf-tab
zstyle ':fzf-tab:*' switch-group '<' '>'
zstyle ':fzf-tab:*' fzf-flags --height=80% --layout=reverse --border
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -la --icons --color=always $realpath'
zstyle ':fzf-tab:complete:z:*' fzf-preview 'eza -la --icons --color=always $realpath'
zstyle ':fzf-tab:complete:ls:*' fzf-preview 'eza -la --icons --color=always $realpath'
zstyle ':fzf-tab:complete:eza:*' fzf-preview 'eza -la --icons --color=always $realpath'

# Suggestions and syntax highlighting (load last)
zinit ice wait"0c" lucid
zinit light zsh-users/zsh-syntax-highlighting

# Aliases
alias ll="eza -la --icons"
alias s="ssh"
alias claude-yolo="claude --dangerously-skip-permissions"

alias -g -- --help='--help 2>&1 | bat -P --language=help --style=plain'

# Keybindings
bindkey "^[[1;3C" forward-word
bindkey "^[[1;3D" backward-word

# External tools initialization
eval "$(starship init zsh)"
eval "$(atuin init zsh)"
# mise: polyglot version manager (node/go/npm/pnpm/yarn). rust/python/bun stay
# on rustup/uv/bun. Global versions live in ~/.config/mise/config.toml.
eval "$(mise activate zsh)"
# zoxide's interactive fzf (zi). Self-contained: zoxide replaces FZF_DEFAULT_OPTS
# rather than appending. No --exact = fuzzy. {2} is the path (score is field 1).
export _ZO_FZF_OPTS="
  --no-sort
  --keep-right
  --cycle
  --info=inline
  --exit-0
  --bind=ctrl-z:ignore,btab:up,tab:down
  --height=80%
  --layout=reverse
  --border
  --preview='eza -la --icons --color=always {2}'
  --preview-window=right,50%,border-left
"
eval "$(zoxide init zsh)"

# zinit aliases `zi` to itself; drop it so `zi` runs zoxide (zpl/zplg/zini stay).
(( ${+aliases[zi]} )) && unalias zi

# Alt-c: zoxide interactive jump. Uses __zoxide_zi to avoid the aliased `zi`.
_zi_widget() {
  __zoxide_zi < /dev/tty
  zle reset-prompt
}
zle -N _zi_widget
bindkey '^[c' _zi_widget   # ^[c == Alt-c

# Functions
mkcd() {
    if (( $# != 1 )); then
        print -u2 "usage: mkcd DIR"
        return 2
    fi

    mkdir -p -- "$1" && z -- "$1"
}

clear() {
  printf '\033[2J\033[3J\033[1;1H'
  command clear
  fastfetch
}

# Show fastfetch on startup
[[ -o interactive ]] && fastfetch
